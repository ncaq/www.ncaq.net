{
  "name": "www-ncaq-net",
  "version": "0.1.1.0",
  "private": true,
  "scripts": {
    "default.css": "sass --load-path=${NODE_PATH:-node_modules} site/default.scss",
    "deploy": "wrangler pages deploy _site --project-name www-ncaq-net",
    "fix": "npm run lint -- --write",
    "lint": "prettier --ignore-path .gitignore --ignore-unknown --check '**/*.{js,jsx,ts,tsx,json,html,css,less,sass,scss,yml,yaml}'"
  },
  "dependencies": {
    "bootstrap": "^4.6.2"
  },
  "devDependencies": {
    "@double-great/stylelint-a11y": "^3.4.5",
    "prettier": "^3.8.1",
    "sass": "^1.99.0",
    "stylelint": "^17.4.0",
    "stylelint-browser-compat": "^1.0.0-beta.180",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-block-no-ignored-properties": "^3.0.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.69.0"
  },
  "engines": {
    "node": ">=22.22.0"
  }
}
