{
  "name": "www-ncaq-net",
  "version": "1.0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "deploy": "wrangler pages deploy _site --project-name www-ncaq-net",
    "fix": "run-p fix:*",
    "fix:prettier": "prettier --write .",
    "fix:stylelint": "stylelint --fix 'site/style/**/*.css'",
    "lint": "run-p lint:*",
    "lint:prettier": "prettier --check .",
    "lint:stylelint": "stylelint 'site/style/**/*.css'",
    "lint:tsc": "tsc --noEmit",
    "watch": "vite build --watch"
  },
  "devDependencies": {
    "@double-great/stylelint-a11y": "^3.4.10",
    "@types/node": "^22",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "stylelint": "^17.8.0",
    "stylelint-browser-compat": "^1.0.0-beta.180",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-block-no-ignored-properties": "^3.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wrangler": "^4.83.0"
  },
  "engines": {
    "node": ">=22.22.0"
  }
}
